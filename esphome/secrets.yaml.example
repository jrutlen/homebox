# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is read by ESPHome at compile time and must NOT be committed.

api_encryption_key: "YOUR_32_BYTE_BASE64_KEY_HERE"   # generate with: openssl rand -base64 32
ota_password: "your-ota-password"
wifi_ssid: "YourNetworkName"
wifi_password: "YourWifiPassword"
ap_fallback_password: "fallback-ap-password"
